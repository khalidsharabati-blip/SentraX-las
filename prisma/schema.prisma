generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// ENUMS
// ========================

enum CustomerType {
  INDIVIDUAL
  BUSINESS
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum MovementType {
  IN
  OUT
}

enum InvoiceType {
  TAX_INVOICE
  TAX_INVOICE_RECEIPT
  CREDIT_NOTE
}

enum PaymentMethod {
  CASH
  CHECK
  BANK_TRANSFER
  CREDIT_CARD
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  RESOLVED
  CLOSED
}

enum LeaveType {
  ANNUAL
  SICK
  PERSONAL
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SalaryType {
  MONTHLY
  HOURLY
  DAILY
}

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
}

enum SerialStatus {
  IN_STOCK
  INSTALLED
  RETURNED
  DEFECTIVE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

// ========================
// AUTH MODULE
// ========================

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  language     String    @default("ar")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  userRoles     UserRole[]
  auditLogs     AuditLog[]
  loginSessions LoginSession[]
  notifications Notification[]
  employee      Employee?
  uploadedPlans Plan[]

  @@map("users")
}

model Role {
  id          Int    @id @default(autoincrement())
  name        String @unique
  displayName String @map("display_name")
  description String @default("")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id     Int    @id @default(autoincrement())
  module String
  action String

  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model UserRole {
  id     Int @id @default(autoincrement())
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           Int @id @default(autoincrement())
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String
  module    String
  recordId  Int?     @map("record_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([module, action])
  @@index([userId])
  @@map("audit_logs")
}

model LoginSession {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_sessions")
}

// ========================
// CRM MODULE
// ========================

model Customer {
  id           Int          @id @default(autoincrement())
  name         String
  companyName  String?      @map("company_name")
  phone        String?
  email        String?
  idNumber     String?      @map("id_number")
  customerType CustomerType @default(BUSINESS) @map("customer_type")
  taxId        String?      @map("tax_id")
  isActive     Boolean      @default(true) @map("is_active")
  notes        String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  contacts             CustomerContact[]
  sites                CustomerSite[]
  documents            CustomerDocument[]
  projects             Project[]
  quotes               Quote[]
  invoices             Invoice[]
  maintenanceContracts MaintenanceContract[]
  serviceTickets       ServiceTicket[]

  @@index([name])
  @@index([phone])
  @@map("customers")
}

model CustomerContact {
  id          Int    @id @default(autoincrement())
  customerId  Int    @map("customer_id")
  contactName String @map("contact_name")
  role        String @default("")
  phone       String @default("")
  email       String @default("")
  isPrimary   Boolean @default(false) @map("is_primary")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_contacts")
}

model CustomerSite {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  siteName   String   @map("site_name")
  address    String   @default("")
  city       String   @default("")
  gpsLat     Decimal? @map("gps_lat") @db.Decimal(10, 7)
  gpsLng     Decimal? @map("gps_lng") @db.Decimal(10, 7)

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  projects Project[]

  @@map("customer_sites")
}

model CustomerDocument {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  docType    String   @map("doc_type")
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_documents")
}

// ========================
// PROJECTS MODULE
// ========================

model Project {
  id               Int           @id @default(autoincrement())
  projectNumber    String        @unique @map("project_number")
  customerId       Int           @map("customer_id")
  siteId           Int?          @map("site_id")
  projectManagerId Int?          @map("project_manager_id")
  name             String
  description      String        @default("")
  projectType      String        @default("general") @map("project_type")
  status           ProjectStatus @default(DRAFT)
  startDate        DateTime?     @map("start_date") @db.Date
  endDate          DateTime?     @map("end_date") @db.Date
  estimatedCost    Decimal       @default(0) @map("estimated_cost") @db.Decimal(12, 2)
  actualCost       Decimal       @default(0) @map("actual_cost") @db.Decimal(12, 2)
  hasCameras       Boolean       @default(false) @map("has_cameras")
  hasAlarm         Boolean       @default(false) @map("has_alarm")
  hasFire          Boolean       @default(false) @map("has_fire")
  hasGates         Boolean       @default(false) @map("has_gates")
  hasAccessControl Boolean       @default(false) @map("has_access_control")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  customer       Customer      @relation(fields: [customerId], references: [id])
  site           CustomerSite? @relation(fields: [siteId], references: [id])
  projectManager Employee?     @relation(fields: [projectManagerId], references: [id])

  tasks              ProjectTask[]
  materials          ProjectMaterial[]
  maps               ProjectMap[]
  invoices           Invoice[]
  deliveryNotes      DeliveryNote[]
  stockMovements     StockMovement[]
  serialNumbers      SerialNumber[]
  maintenanceContracts MaintenanceContract[]
  serviceTickets     ServiceTicket[]
  employeeAttendance EmployeeAttendance[]
  plans              Plan[]

  @@index([customerId])
  @@index([status])
  @@map("projects")
}

model ProjectTask {
  id          Int        @id @default(autoincrement())
  projectId   Int        @map("project_id")
  assignedTo  Int?       @map("assigned_to")
  taskName    String     @map("task_name")
  description String     @default("")
  status      TaskStatus @default(TODO)
  dueDate     DateTime?  @map("due_date") @db.Date
  createdAt   DateTime   @default(now()) @map("created_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee Employee? @relation(fields: [assignedTo], references: [id])

  @@map("project_tasks")
}

model ProjectMaterial {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  itemId    Int     @map("item_id")
  qtyUsed   Decimal @map("qty_used") @db.Decimal(10, 2)
  unitCost  Decimal @map("unit_cost") @db.Decimal(10, 2)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [itemId], references: [id])

  @@map("project_materials")
}

model ProjectMap {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  fileName  String   @map("file_name")
  filePath  String   @map("file_path")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  markers MapMarker[]

  @@map("project_maps")
}

model MapMarker {
  id         Int    @id @default(autoincrement())
  mapId      Int    @map("map_id")
  markerType String @map("marker_type")
  label      String @default("")
  x          Decimal @db.Decimal(8, 2)
  y          Decimal @db.Decimal(8, 2)

  map ProjectMap @relation(fields: [mapId], references: [id], onDelete: Cascade)

  @@map("map_markers")
}

// ========================
// INVENTORY MODULE
// ========================

model Item {
  id             Int      @id @default(autoincrement())
  itemCode       String   @unique @map("item_code")
  nameAr         String   @map("name_ar")
  nameHe         String   @default("") @map("name_he")
  nameEn         String   @default("") @map("name_en")
  categoryId     Int?     @map("category_id")
  brandId        Int?     @map("brand_id")
  unit           String   @default("unit")
  itemType       String   @default("equipment") @map("item_type")
  purchasePrice  Decimal  @default(0) @map("purchase_price") @db.Decimal(10, 2)
  sellPrice      Decimal  @default(0) @map("sell_price") @db.Decimal(10, 2)
  minStockAlert  Int      @default(0) @map("min_stock_alert")
  warrantyMonths Int      @default(0) @map("warranty_months")
  description    String   @default("")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category ItemCategory? @relation(fields: [categoryId], references: [id])
  brand    ItemBrand?    @relation(fields: [brandId], references: [id])

  stockBalances    StockBalance[]
  stockMovements   StockMovement[]
  serialNumbers    SerialNumber[]
  projectMaterials ProjectMaterial[]
  invoiceItems     InvoiceItem[]
  quoteItems       QuoteItem[]
  serviceParts     ServicePart[]

  @@index([itemCode])
  @@map("items")
}

model ItemCategory {
  id          Int     @id @default(autoincrement())
  name        String
  description String  @default("")
  parentId    Int?    @map("parent_id")

  parent   ItemCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ItemCategory[] @relation("CategoryTree")
  items    Item[]

  @@map("item_categories")
}

model ItemBrand {
  id   Int    @id @default(autoincrement())
  name String

  items Item[]

  @@map("item_brands")
}

model Warehouse {
  id   Int    @id @default(autoincrement())
  name String
  location String @default("")

  stockBalances StockBalance[]
  stockMovements StockMovement[]

  @@map("warehouses")
}

model StockBalance {
  id           Int     @id @default(autoincrement())
  itemId       Int     @map("item_id")
  warehouseId  Int     @map("warehouse_id")
  qtyAvailable Decimal @default(0) @map("qty_available") @db.Decimal(10, 2)

  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([itemId, warehouseId])
  @@map("stock_balances")
}

model StockMovement {
  id           Int          @id @default(autoincrement())
  itemId       Int          @map("item_id")
  warehouseId  Int?         @map("warehouse_id")
  projectId    Int?         @map("project_id")
  movementType MovementType @map("movement_type")
  qty          Decimal      @db.Decimal(10, 2)
  unitCost     Decimal      @default(0) @map("unit_cost") @db.Decimal(10, 2)
  reference    String       @default("")
  notes        String       @default("")
  movementDate DateTime     @default(now()) @map("movement_date")
  createdBy    Int?         @map("created_by")

  item      Item       @relation(fields: [itemId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  project   Project?   @relation(fields: [projectId], references: [id])

  @@index([itemId])
  @@index([movementDate])
  @@map("stock_movements")
}

model SerialNumber {
  id              Int          @id @default(autoincrement())
  itemId          Int          @map("item_id")
  projectId       Int?         @map("project_id")
  serialNumber    String       @unique @map("serial_number")
  status          SerialStatus @default(IN_STOCK)
  warrantyEndDate DateTime?    @map("warranty_end_date") @db.Date
  notes           String       @default("")
  createdAt       DateTime     @default(now()) @map("created_at")

  item    Item     @relation(fields: [itemId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([serialNumber])
  @@map("serial_numbers")
}

model Supplier {
  id      Int    @id @default(autoincrement())
  name    String
  contact String @default("")
  phone   String @default("")
  email   String @default("")
  vat     String @default("")
  address String @default("")

  @@map("suppliers")
}

// ========================
// FINANCE MODULE
// ========================

model Quote {
  id          Int         @id @default(autoincrement())
  quoteNumber String      @unique @map("quote_number")
  customerId  Int         @map("customer_id")
  subtotal    Decimal     @default(0) @db.Decimal(12, 2)
  discount    Decimal     @default(0) @db.Decimal(12, 2)
  vatRate     Decimal     @default(0.17) @map("vat_rate") @db.Decimal(5, 4)
  vatAmount   Decimal     @default(0) @map("vat_amount") @db.Decimal(12, 2)
  total       Decimal     @default(0) @db.Decimal(12, 2)
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime?   @map("valid_until") @db.Date
  notes       String      @default("")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  customer Customer    @relation(fields: [customerId], references: [id])
  items    QuoteItem[]
  invoice  Invoice?

  @@index([customerId])
  @@map("quotes")
}

model QuoteItem {
  id          Int     @id @default(autoincrement())
  quoteId     Int     @map("quote_id")
  itemId      Int?    @map("item_id")
  description String
  qty         Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  total       Decimal @db.Decimal(12, 2)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  item  Item? @relation(fields: [itemId], references: [id])

  @@map("quote_items")
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique @map("invoice_number")
  customerId    Int           @map("customer_id")
  projectId     Int?          @map("project_id")
  quoteId       Int?          @unique @map("quote_id")
  invoiceType   InvoiceType   @default(TAX_INVOICE) @map("invoice_type")
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  vatRate       Decimal       @default(0.17) @map("vat_rate") @db.Decimal(5, 4)
  vatAmount     Decimal       @default(0) @map("vat_amount") @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus PaymentStatus @default(UNPAID) @map("payment_status")
  issueDate     DateTime      @default(now()) @map("issue_date") @db.Date
  dueDate       DateTime?     @map("due_date") @db.Date
  notes         String        @default("")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  customer      Customer       @relation(fields: [customerId], references: [id])
  project       Project?       @relation(fields: [projectId], references: [id])
  quote         Quote?         @relation(fields: [quoteId], references: [id])
  items         InvoiceItem[]
  payments      Payment[]
  deliveryNotes DeliveryNote[]

  @@index([customerId])
  @@index([paymentStatus])
  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int     @map("invoice_id")
  itemId      Int?    @map("item_id")
  description String
  qty         Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  total       Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item    Item?   @relation(fields: [itemId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id            Int           @id @default(autoincrement())
  paymentNumber String        @unique @map("payment_number")
  invoiceId     Int           @map("invoice_id")
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  reference     String        @default("")
  paymentDate   DateTime      @default(now()) @map("payment_date") @db.Date
  notes         String        @default("")
  createdAt     DateTime      @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

model DeliveryNote {
  id             Int      @id @default(autoincrement())
  deliveryNumber String   @unique @map("delivery_number")
  projectId      Int?     @map("project_id")
  invoiceId      Int?     @map("invoice_id")
  deliveryDate   DateTime @default(now()) @map("delivery_date") @db.Date
  notes          String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  items   DeliveryNoteItem[]

  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id             Int     @id @default(autoincrement())
  deliveryNoteId Int     @map("delivery_note_id")
  description    String
  qty            Decimal @db.Decimal(10, 2)

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@map("delivery_note_items")
}

model DocumentSequence {
  id         Int    @id @default(autoincrement())
  docType    String @map("doc_type")
  prefix     String
  year       Int
  lastNumber Int    @default(0) @map("last_number")

  @@unique([docType, year])
  @@map("document_sequences")
}

// ========================
// HR MODULE
// ========================

model Employee {
  id           Int          @id @default(autoincrement())
  userId       Int?         @unique @map("user_id")
  fullName     String       @map("full_name")
  idNumber     String       @default("") @map("id_number")
  phone        String       @default("")
  email        String       @default("")
  position     String       @default("")
  department   String       @default("")
  salary       Decimal      @default(0) @db.Decimal(10, 2)
  salaryType   SalaryType   @default(MONTHLY) @map("salary_type")
  contractType ContractType @default(FULL_TIME) @map("contract_type")
  hireDate     DateTime?    @map("hire_date") @db.Date
  isActive     Boolean      @default(true) @map("is_active")
  // Israeli labor fields
  taxCreditPoints   Decimal  @default(2.25) @map("tax_credit_points") @db.Decimal(5, 2)
  pensionRate       Decimal  @default(6.5) @map("pension_rate") @db.Decimal(5, 2)
  pensionEmployer   Decimal  @default(6.5) @map("pension_employer") @db.Decimal(5, 2)
  bituachLeumiRate  Decimal  @default(3.5) @map("bituach_leumi_rate") @db.Decimal(5, 2)
  healthInsurance   Decimal  @default(3.1) @map("health_insurance") @db.Decimal(5, 2)
  travelAllowance   Decimal  @default(0) @map("travel_allowance") @db.Decimal(10, 2)
  convalescenceDays Int      @default(0) @map("convalescence_days")
  numChildren       Int      @default(0) @map("num_children")
  bankName          String   @default("") @map("bank_name")
  bankBranch        String   @default("") @map("bank_branch")
  bankAccount       String   @default("") @map("bank_account")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  attendance     EmployeeAttendance[]
  leaves         EmployeeLeave[]
  salaries       EmployeeSalary[]
  managedProjects Project[]
  assignedTasks  ProjectTask[]
  assignedTickets ServiceTicket[]

  @@map("employees")
}

model EmployeeAttendance {
  id         Int       @id @default(autoincrement())
  employeeId Int       @map("employee_id")
  projectId  Int?      @map("project_id")
  workDate   DateTime  @map("work_date") @db.Date
  clockIn    DateTime? @map("clock_in")
  clockOut   DateTime? @map("clock_out")
  totalHours Decimal   @default(0) @map("total_hours") @db.Decimal(5, 2)
  overtime   Decimal   @default(0) @db.Decimal(5, 2)
  notes      String    @default("")

  employee Employee @relation(fields: [employeeId], references: [id])
  project  Project? @relation(fields: [projectId], references: [id])

  @@index([employeeId, workDate])
  @@map("employee_attendance")
}

model EmployeeLeave {
  id         Int         @id @default(autoincrement())
  employeeId Int         @map("employee_id")
  leaveType  LeaveType   @map("leave_type")
  fromDate   DateTime    @map("from_date") @db.Date
  toDate     DateTime    @map("to_date") @db.Date
  status     LeaveStatus @default(PENDING)
  approvedBy Int?        @map("approved_by")
  notes      String      @default("")
  createdAt  DateTime    @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("employee_leaves")
}

model EmployeeSalary {
  id              Int     @id @default(autoincrement())
  employeeId      Int     @map("employee_id")
  month           Int
  year            Int
  baseSalary      Decimal @map("base_salary") @db.Decimal(10, 2)
  overtimePay     Decimal @default(0) @map("overtime_pay") @db.Decimal(10, 2)
  overtimeHours125 Decimal @default(0) @map("overtime_hours_125") @db.Decimal(5, 2)
  overtimeHours150 Decimal @default(0) @map("overtime_hours_150") @db.Decimal(5, 2)
  travelAllowance Decimal @default(0) @map("travel_allowance") @db.Decimal(10, 2)
  convalescence   Decimal @default(0) @db.Decimal(10, 2)
  bonuses         Decimal @default(0) @db.Decimal(10, 2)
  grossSalary     Decimal @default(0) @map("gross_salary") @db.Decimal(10, 2)
  // Israeli deductions
  incomeTax       Decimal @default(0) @map("income_tax") @db.Decimal(10, 2)
  bituachLeumi    Decimal @default(0) @map("bituach_leumi") @db.Decimal(10, 2)
  healthInsurance Decimal @default(0) @map("health_insurance") @db.Decimal(10, 2)
  pensionEmployee Decimal @default(0) @map("pension_employee") @db.Decimal(10, 2)
  pensionEmployer Decimal @default(0) @map("pension_employer") @db.Decimal(10, 2)
  totalDeductions Decimal @default(0) @map("total_deductions") @db.Decimal(10, 2)
  deductions      Decimal @default(0) @db.Decimal(10, 2)
  netSalary       Decimal @map("net_salary") @db.Decimal(10, 2)
  totalWorkDays   Int     @default(0) @map("total_work_days")
  totalWorkHours  Decimal @default(0) @map("total_work_hours") @db.Decimal(7, 2)
  isPaid          Boolean @default(false) @map("is_paid")
  paidAt          DateTime? @map("paid_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@map("employee_salaries")
}

// ========================
// MAINTENANCE MODULE
// ========================

model MaintenanceContract {
  id             Int            @id @default(autoincrement())
  contractNumber String         @unique @map("contract_number")
  customerId     Int            @map("customer_id")
  projectId      Int?           @map("project_id")
  startDate      DateTime       @map("start_date") @db.Date
  endDate        DateTime       @map("end_date") @db.Date
  visitsPerYear  Int            @default(4) @map("visits_per_year")
  annualPrice    Decimal        @default(0) @map("annual_price") @db.Decimal(10, 2)
  status         ContractStatus @default(ACTIVE)
  notes          String         @default("")
  createdAt      DateTime       @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])
  project  Project? @relation(fields: [projectId], references: [id])
  tickets  ServiceTicket[]

  @@map("maintenance_contracts")
}

model ServiceTicket {
  id             Int            @id @default(autoincrement())
  ticketNumber   String         @unique @map("ticket_number")
  customerId     Int            @map("customer_id")
  projectId      Int?           @map("project_id")
  contractId     Int?           @map("contract_id")
  assignedTechId Int?           @map("assigned_tech_id")
  issueType      String         @default("general") @map("issue_type")
  priority       TicketPriority @default(MEDIUM)
  description    String
  status         TicketStatus   @default(OPEN)
  openedAt       DateTime       @default(now()) @map("opened_at")
  closedAt       DateTime?      @map("closed_at")

  customer     Customer             @relation(fields: [customerId], references: [id])
  project      Project?             @relation(fields: [projectId], references: [id])
  contract     MaintenanceContract? @relation(fields: [contractId], references: [id])
  assignedTech Employee?            @relation(fields: [assignedTechId], references: [id])
  visits       ServiceVisit[]
  parts        ServicePart[]

  @@index([status])
  @@map("service_tickets")
}

model ServiceVisit {
  id        Int      @id @default(autoincrement())
  ticketId  Int      @map("ticket_id")
  techId    Int?     @map("tech_id")
  visitDate DateTime @map("visit_date") @db.Date
  duration  Decimal  @default(0) @db.Decimal(5, 2)
  workDone  String   @default("") @map("work_done")
  result    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  ticket ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("service_visits")
}

model ServicePart {
  id       Int     @id @default(autoincrement())
  ticketId Int     @map("ticket_id")
  itemId   Int     @map("item_id")
  qtyUsed  Int     @default(1) @map("qty_used")
  billable Boolean @default(true)

  ticket ServiceTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  item   Item          @relation(fields: [itemId], references: [id])

  @@map("service_parts")
}

// ========================
// SYSTEM MODULE
// ========================

model Company {
  id        Int    @id @default(autoincrement())
  nameAr    String @map("name_ar")
  nameHe    String @default("") @map("name_he")
  nameEn    String @default("") @map("name_en")
  vatNumber String @default("") @map("vat_number")
  phone     String @default("")
  email     String @default("")
  address   String @default("")
  logoPath  String @default("") @map("logo_path")

  settings CompanySetting[]

  @@map("companies")
}

model CompanySetting {
  id        Int    @id @default(autoincrement())
  companyId Int    @map("company_id")
  key       String
  value     String

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, key])
  @@map("company_settings")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  type      NotificationType @default(INFO)
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  link      String           @default("")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  level     LogLevel @default(INFO)
  message   String
  context   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([level])
  @@map("system_logs")
}

// ========================
// AI PLAN ANALYSIS
// ========================

enum PlanType {
  CCTV
  FIRE_ALARM
  INTRUSION
  NETWORK
  MIXED
}

model Plan {
  id         Int      @id @default(autoincrement())
  projectId  Int?     @map("project_id")
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  fileType   String   @map("file_type")
  planType   PlanType @default(MIXED) @map("plan_type")
  pageCount  Int      @default(1) @map("page_count")
  uploadedBy Int?     @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  project    Project?          @relation(fields: [projectId], references: [id])
  uploadedByUser User?         @relation(fields: [uploadedBy], references: [id])
  legends    PlanLegend[]
  detections PlanDetection[]
  reports    PlanAnalysisReport[]

  @@map("plans")
}

model PlanLegend {
  id             Int     @id @default(autoincrement())
  planId         Int     @map("plan_id")
  symbolName     String  @map("symbol_name")
  symbolLabel    String  @map("symbol_label")
  symbolCategory String  @default("") @map("symbol_category")
  learnedManually Boolean @default(false) @map("learned_manually")
  confidence     Float   @default(0)

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_legends")
}

model PlanDetection {
  id         Int    @id @default(autoincrement())
  planId     Int    @map("plan_id")
  symbolName String @map("symbol_name")
  x          Float  @default(0)
  y          Float  @default(0)
  pageNumber Int    @default(1) @map("page_number")
  confidence Float  @default(0)
  roomName   String @default("") @map("room_name")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_detections")
}

model PlanAnalysisReport {
  id              Int      @id @default(autoincrement())
  planId          Int      @map("plan_id")
  summary         String   @default("")
  recommendations String   @default("")
  quantitiesJson  Json?    @map("quantities_json")
  issuesJson      Json?    @map("issues_json")
  createdAt       DateTime @default(now()) @map("created_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_analysis_reports")
}

model AiSymbolMemory {
  id         Int      @id @default(autoincrement())
  symbolName String   @map("symbol_name")
  aliases    String   @default("")
  category   String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("ai_symbol_memory")
}
